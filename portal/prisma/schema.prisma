// ===========================================
// LumenQuery Portal - Database Schema
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// NextAuth.js Models
// ===========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===========================================
// User & Organization
// ===========================================

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  hashedPassword String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  accounts       Account[]
  sessions       Session[]
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  apiKeys        ApiKey[]
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Stripe
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?

  // Subscription tier
  tier             SubscriptionTier @default(FREE)
  monthlyRequestLimit Int           @default(10000)

  // Soroban Pro limits
  sorobanProEnabled       Boolean  @default(false)
  contractsMonthlyLimit   Int      @default(10)
  callHistoryDays         Int      @default(7)
  aiExplanationsMonthly   Int      @default(0)
  aiExplanationsUsed      Int      @default(0)
  contractsExploredThisMonth Int   @default(0)
  exportEnabled           Boolean  @default(false)
  realtimeStreamEnabled   Boolean  @default(false)

  // Relations
  users            User[]
  apiKeys          ApiKey[]
  usageRecords     UsageRecord[]
}

enum SubscriptionTier {
  FREE
  DEVELOPER    // was STARTER - $25/mo
  TEAM         // was PROFESSIONAL - $99/mo
  ENTERPRISE
  AUDITOR      // per-engagement license
}

// ===========================================
// API Key Management
// ===========================================

model ApiKey {
  id             String    @id @default(cuid())
  name           String
  keyPrefix      String    // First 8 chars for display (lq_xxxxxxxx)
  keyHash        String    @unique // SHA-256 hash of full key
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  // Permissions
  permissions    String[]  @default(["read"])

  // Relations
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  usageRecords   UsageRecord[]

  @@index([keyHash])
}

// ===========================================
// Usage Tracking & Metering
// ===========================================

model UsageRecord {
  id             String   @id @default(cuid())
  timestamp      DateTime @default(now())
  endpoint       String
  method         String
  statusCode     Int
  responseTimeMs Int
  requestSize    Int      @default(0)
  responseSize   Int      @default(0)

  // Relations
  apiKey         ApiKey       @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  apiKeyId       String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  @@index([organizationId, timestamp])
  @@index([apiKeyId, timestamp])
}

// Aggregated daily usage (for billing & dashboards)
model DailyUsage {
  id             String   @id @default(cuid())
  date           DateTime @db.Date
  organizationId String
  totalRequests  Int      @default(0)
  successfulRequests Int  @default(0)
  failedRequests Int      @default(0)
  totalResponseTimeMs BigInt @default(0)
  totalDataTransferBytes BigInt @default(0)

  @@unique([organizationId, date])
  @@index([organizationId, date])
}

// ===========================================
// Soroban Pro - Smart Contract Explorer
// ===========================================

// Contract metadata and indexed data
model Contract {
  id              String   @id @default(cuid())
  contractId      String   @unique  // C... Stellar contract address
  wasmHash        String?
  createdAt       DateTime @default(now())
  createdLedger   Int
  lastSeenLedger  Int
  totalCalls      Int      @default(0)

  // Metadata (fetched/decoded)
  name            String?
  version         String?
  sourceUrl       String?

  // Relations
  calls           ContractCall[]
  storageEntries  ContractStorage[]
  events          ContractEvent[]
  storageSnapshots StorageSnapshot[]

  @@index([contractId])
  @@index([createdAt])
}

// Contract function invocations
model ContractCall {
  id              String   @id @default(cuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  txHash          String
  ledger          Int
  timestamp       DateTime

  // Decoded data
  functionName    String
  inputsRaw       String   @db.Text  // XDR base64
  inputsDecoded   Json?              // Decoded parameters
  outputsRaw      String?  @db.Text
  outputsDecoded  Json?

  // Execution details
  status          String   // success, failed
  errorCode       String?
  gasUsed         BigInt?

  // AI explanation (cached per call)
  aiExplanation   String?  @db.Text

  @@index([contractId, timestamp])
  @@index([txHash])
  @@index([ledger])
  @@index([functionName])
}

// Contract storage entries
model ContractStorage {
  id                  String   @id @default(cuid())
  contractId          String
  contract            Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  storageKey          String   // XDR key
  storageKeyDecoded   String?
  storageValue        String   @db.Text  // XDR value
  storageValueDecoded Json?

  ledger              Int
  timestamp           DateTime @default(now())

  @@unique([contractId, storageKey, ledger])
  @@index([contractId])
}

// Contract events
model ContractEvent {
  id              String   @id @default(cuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  eventId         String   @unique
  txHash          String
  ledger          Int
  timestamp       DateTime

  eventType       String   // system, contract, diagnostic
  topics          Json     // Decoded topics array
  data            Json?    // Decoded event data

  @@index([contractId, timestamp])
  @@index([txHash])
}

// Storage size snapshots for growth tracking
model StorageSnapshot {
  id              String   @id @default(cuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  ledger          Int
  timestamp       DateTime @default(now())
  totalEntries    Int
  totalSizeBytes  BigInt

  @@unique([contractId, ledger])
  @@index([contractId, timestamp])
}

// AI explanation cache (global, shared across users)
model AIExplanationCache {
  id              String   @id @default(cuid())
  callHash        String   @unique  // Hash of function+inputs for dedup
  explanation     String   @db.Text
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  @@index([callHash])
}
