// ===========================================
// LumenQuery Portal - Database Schema
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// NextAuth.js Models
// ===========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  @@index([email])
  @@index([token])
}

// ===========================================
// User & Organization
// ===========================================

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  hashedPassword String?
  role           UserRole  @default(USER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Session tracking
  lastLoginAt       DateTime?
  lastActiveAt      DateTime?
  currentSessionStart DateTime?

  // Relations
  accounts       Account[]
  sessions       Session[]
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  apiKeys        ApiKey[]

  // Admin audit relations
  adminActions   AdminAuditLog[] @relation("AdminActions")
  auditedActions AdminAuditLog[] @relation("AuditedActions")
}

// Admin audit log for tracking admin actions
model AdminAuditLog {
  id           String   @id @default(cuid())
  adminId      String
  admin        User     @relation("AdminActions", fields: [adminId], references: [id])
  action       String   // PASSWORD_RESET, USER_DISABLED, USER_UPDATED, etc.
  targetUserId String?
  targetUser   User?    @relation("AuditedActions", fields: [targetUserId], references: [id])
  details      Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
  @@index([createdAt])
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Stripe
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?

  // Subscription tier
  tier             SubscriptionTier @default(FREE)
  monthlyRequestLimit Int           @default(10000)

  // Soroban Pro limits
  sorobanProEnabled       Boolean  @default(false)
  contractsMonthlyLimit   Int      @default(10)
  callHistoryDays         Int      @default(7)
  contractsExploredThisMonth Int   @default(0)
  exportEnabled           Boolean  @default(false)
  realtimeStreamEnabled   Boolean  @default(false)

  // Intelligence tier limits
  intelligenceEnabled       Boolean          @default(false)
  intelligenceTier          IntelligenceTier @default(NONE)
  maxConcurrentStreams      Int              @default(0)
  maxWatchlistAccounts      Int              @default(0)
  maxAlertConfigurations    Int              @default(0)
  alertRetentionDays        Int              @default(30)

  // Compliance tier limits
  complianceEnabled         Boolean          @default(false)
  complianceTier            ComplianceTier   @default(NONE)
  maxMonitoredAccounts      Int              @default(0)
  maxComplianceRules        Int              @default(0)
  auditRetentionDays        Int              @default(365)
  notifySlack               Boolean          @default(false)
  slackWebhookUrl           String?
  complianceEmail           String?

  // Portfolio tier limits
  portfolioEnabled          Boolean          @default(false)
  portfolioTier             PortfolioTier    @default(NONE)
  maxPortfolioAccounts      Int              @default(1)
  maxPortfolios             Int              @default(1)
  yieldTrackingEnabled      Boolean          @default(false)
  pnlTrackingEnabled        Boolean          @default(false)
  contractPositionsEnabled  Boolean          @default(false)
  snapshotRetentionDays     Int              @default(30)

  // Relations
  users               User[]
  apiKeys             ApiKey[]
  usageRecords        UsageRecord[]
  watchlists          Watchlist[]
  alertConfigurations AlertConfiguration[]
  alerts              Alert[]
  complianceRules     ComplianceRule[]
  complianceViolations ComplianceViolation[]
  monitoredAccounts   MonitoredAccount[]
  auditLogEntries     AuditLogEntry[]
  complianceReports   ComplianceReport[]
  portfolios          Portfolio[]
}

enum SubscriptionTier {
  FREE
  DEVELOPER    // was STARTER - $25/mo
  TEAM         // was PROFESSIONAL - $99/mo
  ENTERPRISE
  AUDITOR      // per-engagement license
}

enum IntelligenceTier {
  NONE
  SOLO        // $49/mo - individual traders/analysts
  TEAMS       // $199/mo - funds, compliance teams
  ENTERPRISE  // Custom - alerts + extended retention
}

enum ComplianceTier {
  NONE
  BASIC       // $49/mo - 100 accounts, basic rules
  STANDARD    // $149/mo - 500 accounts, sanctions, reports
  ENTERPRISE  // Custom - unlimited, full features
}

enum PortfolioTier {
  NONE
  FREE        // 1 account, basic tracking
  PRO         // $10/mo - 10 accounts, full P&L, yield
  DAO         // $50/mo - unlimited, team access, custom dashboards
}

enum ComplianceRuleType {
  SANCTIONS_SCREENING
  VELOCITY_LIMIT
  VOLUME_LIMIT
  CIRCULAR_PAYMENT
  MIXER_DETECTION
  UNUSUAL_PATTERN
  COUNTERPARTY_RISK
  CONTRACT_ABUSE
  STRUCTURING
  DORMANT_ACTIVATION
}

enum ViolationStatus {
  PENDING
  UNDER_REVIEW
  CLEARED
  CONFIRMED
  ESCALATED
  REPORTED
}

enum MonitoringLevel {
  BASIC
  STANDARD
  ENHANCED
  RESTRICTED
}

// ===========================================
// API Key Management
// ===========================================

model ApiKey {
  id             String    @id @default(cuid())
  name           String
  keyPrefix      String    // First 8 chars for display (lq_xxxxxxxx)
  keyHash        String    @unique // SHA-256 hash of full key
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  // Permissions
  permissions    String[]  @default(["read"])

  // Relations
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  usageRecords   UsageRecord[]

  @@index([keyHash])
}

// ===========================================
// Usage Tracking & Metering
// ===========================================

model UsageRecord {
  id             String   @id @default(cuid())
  timestamp      DateTime @default(now())
  endpoint       String
  method         String
  statusCode     Int
  responseTimeMs Int
  requestSize    Int      @default(0)
  responseSize   Int      @default(0)

  // Relations
  apiKey         ApiKey       @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  apiKeyId       String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  @@index([organizationId, timestamp])
  @@index([apiKeyId, timestamp])
}

// Aggregated daily usage (for billing & dashboards)
model DailyUsage {
  id             String   @id @default(cuid())
  date           DateTime @db.Date
  organizationId String
  totalRequests  Int      @default(0)
  successfulRequests Int  @default(0)
  failedRequests Int      @default(0)
  totalResponseTimeMs BigInt @default(0)
  totalDataTransferBytes BigInt @default(0)

  @@unique([organizationId, date])
  @@index([organizationId, date])
}

// ===========================================
// Soroban Pro - Smart Contract Explorer
// ===========================================

// Contract metadata and indexed data
model Contract {
  id              String   @id @default(cuid())
  contractId      String   @unique  // C... Stellar contract address
  wasmHash        String?
  createdAt       DateTime @default(now())
  createdLedger   Int
  lastSeenLedger  Int
  totalCalls      Int      @default(0)

  // Metadata (fetched/decoded)
  name            String?
  version         String?
  sourceUrl       String?

  // Relations
  calls           ContractCall[]
  storageEntries  ContractStorage[]
  events          ContractEvent[]
  storageSnapshots StorageSnapshot[]

  @@index([contractId])
  @@index([createdAt])
}

// Contract function invocations
model ContractCall {
  id              String   @id @default(cuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  txHash          String
  ledger          Int
  timestamp       DateTime

  // Decoded data
  functionName    String
  inputsRaw       String   @db.Text  // XDR base64
  inputsDecoded   Json?              // Decoded parameters
  outputsRaw      String?  @db.Text
  outputsDecoded  Json?

  // Execution details
  status          String   // success, failed
  errorCode       String?
  gasUsed         BigInt?

  @@index([contractId, timestamp])
  @@index([txHash])
  @@index([ledger])
  @@index([functionName])
}

// Contract storage entries
model ContractStorage {
  id                  String   @id @default(cuid())
  contractId          String
  contract            Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  storageKey          String   // XDR key
  storageKeyDecoded   String?
  storageValue        String   @db.Text  // XDR value
  storageValueDecoded Json?

  ledger              Int
  timestamp           DateTime @default(now())

  @@unique([contractId, storageKey, ledger])
  @@index([contractId])
}

// Contract events
model ContractEvent {
  id              String   @id @default(cuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  eventId         String   @unique
  txHash          String
  ledger          Int
  timestamp       DateTime

  eventType       String   // system, contract, diagnostic
  topics          Json     // Decoded topics array
  data            Json?    // Decoded event data

  @@index([contractId, timestamp])
  @@index([txHash])
}

// Storage size snapshots for growth tracking
model StorageSnapshot {
  id              String   @id @default(cuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  ledger          Int
  timestamp       DateTime @default(now())
  totalEntries    Int
  totalSizeBytes  BigInt

  @@unique([contractId, ledger])
  @@index([contractId, timestamp])
}

// ===========================================
// Transaction Intelligence Dashboard
// ===========================================

// Watchlist for monitoring Stellar accounts
model Watchlist {
  id              String   @id @default(cuid())
  name            String
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accounts        WatchlistAccount[]

  @@index([organizationId])
}

model WatchlistAccount {
  id          String   @id @default(cuid())
  accountId   String   // Stellar G... address
  label       String?  // User-defined label
  addedAt     DateTime @default(now())

  // Relations
  watchlistId String
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, accountId])
  @@index([accountId])
}

// Account behavior profiling
model AccountProfile {
  id                    String   @id @default(cuid())
  accountId             String   @unique  // Stellar G... address
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Behavior metrics
  totalTransactions     Int      @default(0)
  totalVolume           Decimal  @default(0) @db.Decimal(38, 7)
  avgTransactionSize    Decimal  @default(0) @db.Decimal(38, 7)
  maxTransactionSize    Decimal  @default(0) @db.Decimal(38, 7)

  // Activity patterns
  firstSeen             DateTime?
  lastSeen              DateTime?
  avgTxPerDay           Float    @default(0)
  peakHour              Int?     // 0-23 hour of most activity
  preferredAssets       Json?    // Array of asset codes

  // Counterparty analysis
  uniqueCounterparties  Int      @default(0)
  topCounterparties     Json?    // Top 10 counterparties with tx counts

  // Classification
  accountType           AccountType @default(UNKNOWN)
  riskScore             Int         @default(0) // 0-100
  tags                  String[]

  // Trustline metrics
  trustlineCount        Int      @default(0)
  trustlineChanges30d   Int      @default(0)

  @@index([accountType])
  @@index([riskScore])
  @@index([lastSeen])
}

enum AccountType {
  UNKNOWN
  RETAIL
  EXCHANGE
  MARKET_MAKER
  WHALE
  ISSUER
  ANCHOR
  CONTRACT
}

// Alert configurations
model AlertConfiguration {
  id              String    @id @default(cuid())
  name            String
  description     String?
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Alert type and conditions
  alertType       AlertType
  conditions      Json      // Type-specific conditions

  // Notification settings
  notifyEmail     Boolean   @default(true)
  notifyWebhook   Boolean   @default(false)
  webhookUrl      String?

  // Cooldown to prevent alert spam
  cooldownMinutes Int       @default(5)
  lastTriggered   DateTime?

  // Relations
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  alerts          Alert[]

  @@index([organizationId])
  @@index([alertType, enabled])
}

enum AlertType {
  WHALE_MOVEMENT      // Large XLM transfers
  TRUSTLINE_CHANGE    // Trustline creation/removal
  ACCOUNT_ACTIVITY    // Activity on watched accounts
  CONTRACT_CALL       // Specific contract function calls
  ANOMALY_DETECTED    // Unusual behavior patterns
}

model Alert {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  readAt          DateTime?

  // Alert details
  severity        AlertSeverity
  title           String
  message         String   @db.Text
  data            Json     // Additional context (tx hash, account, etc.)

  // Source information
  sourceType      String   // transaction, account, contract, etc.
  sourceId        String   // Transaction hash, account ID, etc.

  // Relations
  configId        String
  config          AlertConfiguration @relation(fields: [configId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, readAt])
  @@index([configId])
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// ===========================================
// Compliance & AML Monitoring
// ===========================================

// Compliance rule configuration
model ComplianceRule {
  id              String              @id @default(cuid())
  name            String
  description     String?
  ruleType        ComplianceRuleType
  enabled         Boolean             @default(true)
  priority        Int                 @default(50)
  conditions      Json
  thresholds      Json?
  severity        AlertSeverity       @default(WARNING)
  autoBlock       Boolean             @default(false)
  requireReview   Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  violations      ComplianceViolation[]

  @@index([organizationId, enabled])
}

// Compliance violations (triggered alerts)
model ComplianceViolation {
  id              String          @id @default(cuid())
  createdAt       DateTime        @default(now())
  severity        AlertSeverity
  status          ViolationStatus @default(PENDING)
  score           Int             @default(0)

  // Involved entities
  accountId       String
  counterpartyId  String?
  transactionHash String?
  contractId      String?

  // Rule reference
  ruleId          String
  rule            ComplianceRule  @relation(fields: [ruleId], references: [id])

  // Evidence
  matchDetails    Json
  evidenceData    Json

  // Review workflow
  reviewedBy      String?
  reviewedAt      DateTime?
  resolution      String?
  notes           String?         @db.Text

  // Relations
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditTrail      AuditLogEntry[]

  @@index([organizationId, status])
  @@index([accountId])
}

// Monitored accounts for compliance
model MonitoredAccount {
  id               String          @id @default(cuid())
  accountId        String          // Stellar G... address
  label            String?
  addedAt          DateTime        @default(now())
  monitoringLevel  MonitoringLevel @default(STANDARD)
  customThresholds Json?

  // Risk assessment
  riskScore        Int             @default(0)
  riskFactors      Json?
  lastAssessed     DateTime?
  lastActivity     DateTime?

  // Activity metrics
  totalVolume30d   Decimal         @default(0) @db.Decimal(38, 7)
  txCount30d       Int             @default(0)

  // Relations
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, accountId])
  @@index([accountId])
}

// Sanctioned accounts database (OFAC/SDN/etc.)
model SanctionedAccount {
  id              String    @id @default(cuid())
  accountId       String    @unique  // Stellar G... address
  source          String    // OFAC, SDN, EU, UN, COMMUNITY
  listType        String    // SDN, CONSOLIDATED, etc.
  name            String?
  aliases         String[]
  country         String?
  addedAt         DateTime
  lastVerified    DateTime
  metadata        Json?

  @@index([accountId])
}

// Immutable audit log with hash chain
model AuditLogEntry {
  id              String    @id @default(cuid())
  timestamp       DateTime  @default(now())
  action          String    // CREATE, UPDATE, DELETE, REVIEW, ESCALATE, etc.
  entityType      String    // violation, rule, account, etc.
  entityId        String

  // Actor information
  actorType       String    // USER, SYSTEM, WORKER
  actorId         String?
  actorEmail      String?

  // State change
  previousState   Json?
  newState        Json?
  metadata        Json?

  // Hash chain for integrity
  contentHash     String
  previousHash    String?

  // Relations
  organizationId  String
  organization    Organization         @relation(fields: [organizationId], references: [id])
  violationId     String?
  violation       ComplianceViolation? @relation(fields: [violationId], references: [id])

  @@index([organizationId, timestamp])
}

// Payment graph edges for cycle detection
model PaymentGraphEdge {
  id              String    @id @default(cuid())
  fromAccount     String
  toAccount       String
  amount          Decimal   @db.Decimal(38, 7)
  assetCode       String    @default("XLM")
  timestamp       DateTime
  transactionHash String
  hopNumber       Int?
  cycleId         String?

  @@index([fromAccount, timestamp])
  @@index([toAccount, timestamp])
}

// Detected payment cycles
model PaymentCycle {
  id              String          @id @default(cuid())
  detectedAt      DateTime        @default(now())
  accounts        String[]        // Accounts in the cycle
  hopCount        Int
  totalValue      Decimal         @db.Decimal(38, 7)
  timeSpan        Int             // Time span in seconds
  riskScore       Int
  patternType     String          // CIRCULAR, MIXER, LAYERING, etc.
  status          ViolationStatus @default(PENDING)
  organizationId  String

  @@index([organizationId, status])
}

// Compliance reports
model ComplianceReport {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  reportType      String    // DAILY_SUMMARY, WEEKLY, MONTHLY, SAR, AUDIT
  title           String
  period          String    // "2026-02-01 to 2026-02-28"
  summary         Json
  violations      Json
  accounts        Json
  metrics         Json
  generatedBy     String?
  format          String    @default("json") // json, csv, pdf
  fileUrl         String?

  // Relations
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

// Notification delivery tracking
model NotificationDelivery {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  channel         String    // EMAIL, SLACK, WEBHOOK
  recipient       String
  subject         String?
  body            String    @db.Text
  status          String    @default("PENDING") // PENDING, SENT, FAILED
  sentAt          DateTime?
  failureReason   String?
  retryCount      Int       @default(0)
  violationId     String?
  organizationId  String

  @@index([organizationId, status])
}

// Background job tracking
model BackgroundJob {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  jobType         String    // SANCTIONS_SYNC, ACCOUNT_SCAN, CYCLE_DETECTION, REPORT, NOTIFICATION, RISK_ASSESSMENT
  priority        Int       @default(50)
  payload         Json
  status          String    @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  progress        Int       @default(0) // 0-100
  result          Json?
  error           String?
  retryCount      Int       @default(0)

  @@index([status, priority])
}

// ===========================================
// Portfolio + Yield Intelligence
// ===========================================

// Portfolio - aggregates multiple Stellar accounts
model Portfolio {
  id              String    @id @default(cuid())
  name            String
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isDefault       Boolean   @default(false)
  currency        String    @default("USD")  // Display currency

  // Total portfolio metrics (cached, updated periodically)
  totalValueUsd   Decimal   @default(0) @db.Decimal(38, 2)
  totalValueXlm   Decimal   @default(0) @db.Decimal(38, 7)
  totalPnlUsd     Decimal   @default(0) @db.Decimal(38, 2)
  totalPnlPercent Float     @default(0)
  lastSyncedAt    DateTime?

  // Relations
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accounts        PortfolioAccount[]
  positions       AssetPosition[]
  trades          TradeRecord[]
  yieldSources    YieldSource[]
  snapshots       PerformanceSnapshot[]

  @@index([organizationId])
}

// Stellar accounts linked to a portfolio
model PortfolioAccount {
  id              String    @id @default(cuid())
  accountId       String    // Stellar G... address
  label           String?   // User-defined label (e.g., "Trading", "Savings")
  addedAt         DateTime  @default(now())

  // Account metadata (cached from Horizon)
  sequence        BigInt?
  lastActivity    DateTime?
  numSubentries   Int       @default(0)

  // Balance summary (cached)
  xlmBalance      Decimal   @default(0) @db.Decimal(38, 7)
  totalValueUsd   Decimal   @default(0) @db.Decimal(38, 2)

  // Relations
  portfolioId     String
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  positions       AssetPosition[]
  trades          TradeRecord[]
  contractPositions ContractPosition[]
  yieldRewards    YieldReward[]

  @@unique([portfolioId, accountId])
  @@index([accountId])
}

// Asset positions with cost basis for P&L tracking
model AssetPosition {
  id              String    @id @default(cuid())
  assetCode       String    // "XLM", "USDC", etc.
  assetIssuer     String?   // Null for native XLM
  assetType       AssetType @default(CREDIT_ALPHANUM4)

  // Current position
  balance         Decimal   @db.Decimal(38, 7)
  limit           Decimal?  @db.Decimal(38, 7)  // Trustline limit

  // Cost basis tracking
  avgCostBasis    Decimal   @default(0) @db.Decimal(38, 8)  // Avg price paid
  totalCostUsd    Decimal   @default(0) @db.Decimal(38, 2)

  // Current value
  currentPrice    Decimal   @default(0) @db.Decimal(38, 8)
  currentValueUsd Decimal   @default(0) @db.Decimal(38, 2)

  // P&L
  unrealizedPnl   Decimal   @default(0) @db.Decimal(38, 2)
  realizedPnl     Decimal   @default(0) @db.Decimal(38, 2)
  pnlPercent      Float     @default(0)

  // Risk metrics
  riskLevel       RiskLevel @default(LOW)
  issuerTrustScore Int?     // 0-100 for issued assets
  liquidityScore  Int?      // 0-100 based on trading volume

  // Timestamps
  firstAcquired   DateTime?
  lastUpdated     DateTime  @default(now())

  // Relations
  portfolioId     String
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  accountId       String
  account         PortfolioAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, accountId, assetCode, assetIssuer])
  @@index([assetCode])
}

enum AssetType {
  NATIVE
  CREDIT_ALPHANUM4
  CREDIT_ALPHANUM12
  LIQUIDITY_POOL_SHARES
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Trade records for P&L calculation
model TradeRecord {
  id              String    @id @default(cuid())
  txHash          String
  ledger          Int
  timestamp       DateTime
  tradeType       TradeType

  // Base asset (what was sold/exchanged from)
  baseAssetCode   String
  baseAssetIssuer String?
  baseAmount      Decimal   @db.Decimal(38, 7)

  // Counter asset (what was bought/exchanged to)
  counterAssetCode   String
  counterAssetIssuer String?
  counterAmount      Decimal   @db.Decimal(38, 7)

  // Price information
  price           Decimal   @db.Decimal(38, 8)  // Counter per base
  priceUsd        Decimal?  @db.Decimal(38, 8)  // USD price at time of trade
  feeXlm          Decimal   @default(0) @db.Decimal(38, 7)
  feeUsd          Decimal   @default(0) @db.Decimal(38, 4)

  // P&L impact
  realizedPnlUsd  Decimal   @default(0) @db.Decimal(38, 2)
  costBasisUsed   Decimal   @default(0) @db.Decimal(38, 2)

  // Source
  source          String    @default("DEX")  // DEX, AMM, PATHFIND

  // Relations
  portfolioId     String
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  accountId       String
  account         PortfolioAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([portfolioId, timestamp])
  @@index([txHash])
}

enum TradeType {
  BUY
  SELL
  SWAP
  LIQUIDITY_ADD
  LIQUIDITY_REMOVE
}

// Soroban contract positions (DeFi, staking, etc.)
model ContractPosition {
  id              String    @id @default(cuid())
  contractId      String    // Soroban contract address
  contractName    String?   // Human-readable name
  positionType    PositionType

  // Position details
  depositedAmount Decimal   @db.Decimal(38, 7)
  depositedAsset  String
  currentValue    Decimal   @default(0) @db.Decimal(38, 7)
  currentValueUsd Decimal   @default(0) @db.Decimal(38, 2)

  // Staking/LP specific
  shareBalance    Decimal?  @db.Decimal(38, 7)  // LP tokens or staked shares
  rewardsEarned   Decimal   @default(0) @db.Decimal(38, 7)
  rewardsAsset    String?

  // Status
  status          PositionStatus @default(ACTIVE)
  lockedUntil     DateTime?  // For locked staking
  apy             Float?     // Current APY

  // Timestamps
  enteredAt       DateTime
  exitedAt        DateTime?
  lastUpdated     DateTime  @default(now())

  // Relations
  accountId       String
  account         PortfolioAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  yieldRewards    YieldReward[]

  @@index([accountId])
  @@index([contractId])
}

enum PositionType {
  STAKING
  LIQUIDITY_POOL
  LENDING
  BORROWING
  VAULT
  OTHER
}

enum PositionStatus {
  ACTIVE
  LOCKED
  WITHDRAWING
  CLOSED
}

// Yield sources configuration
model YieldSource {
  id              String    @id @default(cuid())
  name            String
  sourceType      YieldSourceType
  contractId      String?   // For contract-based yield
  assetCode       String    // Asset that earns yield
  assetIssuer     String?

  // Yield details
  currentApy      Float     @default(0)
  apyHistory      Json?     // Historical APY data
  compoundingFreq String?   // "daily", "weekly", "epoch"
  minDeposit      Decimal?  @db.Decimal(38, 7)

  // Status
  isActive        Boolean   @default(true)
  riskLevel       RiskLevel @default(MEDIUM)
  lastUpdated     DateTime  @default(now())

  // Relations
  portfolioId     String
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  rewards         YieldReward[]

  @@index([portfolioId])
}

enum YieldSourceType {
  STAKING_NATIVE      // Native XLM staking (when available)
  STAKING_CONTRACT    // Soroban contract staking
  LIQUIDITY_POOL      // AMM LP rewards
  LENDING             // Lending protocol interest
  REWARDS             // Airdrops, grants, etc.
  OTHER
}

// Individual yield rewards earned
model YieldReward {
  id              String    @id @default(cuid())
  timestamp       DateTime
  txHash          String?

  // Reward details
  rewardAsset     String
  rewardIssuer    String?
  amount          Decimal   @db.Decimal(38, 7)
  valueUsd        Decimal?  @db.Decimal(38, 4)

  // Context
  epochNumber     Int?      // For epoch-based rewards
  periodStart     DateTime?
  periodEnd       DateTime?

  // Relations
  yieldSourceId   String?
  yieldSource     YieldSource? @relation(fields: [yieldSourceId], references: [id], onDelete: SetNull)
  accountId       String
  account         PortfolioAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contractPositionId String?
  contractPosition ContractPosition? @relation(fields: [contractPositionId], references: [id], onDelete: SetNull)

  @@index([accountId, timestamp])
  @@index([yieldSourceId])
}

// Historical performance snapshots
model PerformanceSnapshot {
  id              String    @id @default(cuid())
  timestamp       DateTime  @default(now())
  snapshotType    SnapshotType @default(DAILY)

  // Portfolio value
  totalValueUsd   Decimal   @db.Decimal(38, 2)
  totalValueXlm   Decimal   @db.Decimal(38, 7)

  // P&L since inception
  totalPnlUsd     Decimal   @db.Decimal(38, 2)
  totalPnlPercent Float

  // Period changes (since last snapshot)
  periodChangeUsd    Decimal  @default(0) @db.Decimal(38, 2)
  periodChangePercent Float   @default(0)

  // Asset breakdown
  assetAllocation Json      // { "XLM": 50.5, "USDC": 30.2, ... }
  topPositions    Json      // Top 5 positions with values

  // Yield metrics
  yieldEarnedPeriod  Decimal  @default(0) @db.Decimal(38, 4)
  totalYieldEarned   Decimal  @default(0) @db.Decimal(38, 4)

  // Risk metrics
  diversificationScore Int?   // 0-100
  avgTrustlineRisk     Float?

  // Relations
  portfolioId     String
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, timestamp, snapshotType])
  @@index([portfolioId, timestamp])
}

enum SnapshotType {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

// Trustline risk assessment
model TrustlineRisk {
  id              String    @id @default(cuid())
  accountId       String    // Portfolio account
  assetCode       String
  assetIssuer     String

  // Issuer assessment
  issuerName      String?
  issuerDomain    String?
  issuerVerified  Boolean   @default(false)

  // Risk factors
  riskScore       Int       @default(50)  // 0-100, higher = more risk
  riskFactors     Json      // Array of risk factors

  // Metrics
  totalSupply     Decimal?  @db.Decimal(38, 7)
  holderCount     Int?
  tradingVolume24h Decimal? @db.Decimal(38, 7)
  priceVolatility Float?    // 30-day volatility %

  // Authorization flags
  authRequired    Boolean   @default(false)
  authRevocable   Boolean   @default(false)
  authImmutable   Boolean   @default(false)
  authClawback    Boolean   @default(false)

  // Timestamps
  assessedAt      DateTime  @default(now())
  lastUpdated     DateTime  @default(now())

  @@unique([accountId, assetCode, assetIssuer])
  @@index([riskScore])
}
